{
  "name": "@aws/ftr-eval-mcp",
  "version": "1.0.0",
  "description": "MCP server exposing a local FTR (Foundational Technical Review) evaluation tool for updated criterion.",
  "main": "dist/server.js",
  "bin": {
    "ftr-eval-mcp": "./dist/server.js"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist/",
    "LICENSE",
    "NOTICE"
  ],
  "scripts": {
    "prepare": "npm run build",
    "build": "tsc && npm run copy-assets && chmod +x dist/server.js",
    "copy-assets": "cp -r src/assets dist/assets",
    "start": "node dist/server.js",
    "test": "vitest --run",
    "test:watch": "vitest",
    "build:binaries": "npm run build && npx @yao-pkg/pkg . --out-path binaries/"
  },
  "keywords": [
    "mcp",
    "ftr",
    "aws",
    "evaluation",
    "bedrock"
  ],
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.1075.0",
    "@aws-sdk/client-sts": "^3.1075.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "inquirer": "^9.0.0",
    "ora": "^7.0.0",
    "pdf-parse": "^1.1.1"
  },
  "devDependencies": {
    "@types/inquirer": "^9.0.0",
    "@types/node": "^20.0.0",
    "@yao-pkg/pkg": "^6.21.0",
    "typescript": "^5.4.0",
    "vitest": "^4.1.10"
  },
  "pkg": {
    "targets": [
      "node18-macos-arm64",
      "node18-macos-x64",
      "node18-linux-x64",
      "node18-linux-arm64",
      "node18-win-x64"
    ],
    "assets": [
      "dist/assets/**/*"
    ],
    "outputPath": "binaries"
  }
}
