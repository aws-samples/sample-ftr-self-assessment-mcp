    if [ -x "$_WRAPPER" ]; then
        CSE_CMD="$_WRAPPER"
    else
        echo "❌ cse not found on PATH and no bin/cse wrapper found."
        echo "   Install via: toolbox install cse"
        echo "   (First-time setup: toolbox registry add s3://buildertoolbox-registry-chrysanthemum-us-west-2/tools.json)"
        exit 1
    fi
fi

echo "🔍 Running CSE security scan before CR..."
$CSE_CMD scan --async
exit 0
