# CSE_PRE_CR_VARIANT: advisory
# Runs an async security scan before CRUX code review creation.
# All arguments passed to `cr` are forwarded to this hook.
# Resolve cse binary — prefer PATH, then fall back to the venv
# that lives next to the installed bin/cse wrapper.
if command -v cse &>/dev/null; then
    CSE_CMD="cse"
else
    # Try to find the wrapper relative to this repo's checkout
    _SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/../../.." 2>/dev/null && pwd)"
